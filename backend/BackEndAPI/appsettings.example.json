{
  "_documentation": "Template cấu hình. Copy thành appsettings.json cho dev, hoặc set các giá trị qua env var / Azure Key Vault cho production. Mọi __PLACEHOLDER__ phải được thay thế trước khi run.",

  "ConnectionStrings": {
    "DefaultConnection": "__ENCRYPTED_CONNECTION_STRING__"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "_comment": "Production: liệt kê origin được phép gọi API. Bỏ trống/null sẽ throw khi start.",
    "AllowedOrigins": [
      "https://example.com",
      "https://admin.example.com"
    ]
  },
  "ZaloTokenConfig": {
    "RefreshToken": "__ZALO_REFRESH_TOKEN__",
    "AppId": "__ZALO_APP_ID__",
    "SecretKey": "__ZALO_SECRET_KEY__",
    "TokenUrl": "https://oauth.zaloapp.com/v4/oa/access_token"
  },
  "AllowedHosts": "*",
  "Jwt": {
    "_comment": "Key phải >= 32 ký tự. Issuer/Audience phải khớp domain prod thực tế.",
    "Key": "__JWT_SIGNING_KEY_BASE64__",
    "Issuer": "https://api.example.com",
    "Audience": "https://app.example.com"
  },
  "MailSettings": {
    "Host": "smtp.example.com",
    "DefaultCredentials": false,
    "Port": 465,
    "Name": "Display Name",
    "EmailId": "noreply@example.com",
    "UserName": "noreply@example.com",
    "Password": "__SMTP_PASSWORD__",
    "link": "",
    "UseSSL": true
  },
  "SmtpSettings": {
    "Host": "smtp.office365.com",
    "Port": 587,
    "Username": "noreply@example.com",
    "Password": "__SMTP_PASSWORD__",
    "EnableSsl": true
  },
  "Endpoints": {
    "Host": "http://internal-proxy.example.com/api"
  },
  "SAPServiceLayer": {
    "Host": "https://sap.internal:50000/b1s/v1/",
    "CompanyDB": "__ENCRYPTED_SAP_COMPANY_DB__",
    "Username": "__ENCRYPTED_SAP_USERNAME__",
    "Password": "__ENCRYPTED_SAP_PASSWORD__",
    "Link": "https://portal.example.com/reset-password?token="
  },
  "PayoneConfig": {
    "PayNow": {
      "Id": "__ONEPAY_PAYNOW_ID__",
      "AccessCode": "__ONEPAY_PAYNOW_ACCESS_CODE__",
      "HashCode": "__ONEPAY_PAYNOW_HASH_CODE__"
    },
    "Installment": {
      "Id": "__ONEPAY_INSTALLMENT_ID__",
      "AccessCode": "__ONEPAY_INSTALLMENT_ACCESS_CODE__",
      "HashCode": "__ONEPAY_INSTALLMENT_HASH_CODE__"
    },
    "BaseUrl": "https://onepay.vn",
    "UrlPrefix": "/paygate/vpcpay.op?",
    "RedirectLink": "https://portal.example.com/payment-status",
    "Host": "onepay.vn"
  },
  "VnpaySettings": {
    "VnpUrl": "https://pay.vnpay.vn/vpcpay.html",
    "VnpApi": "https://vnpayment.vn/merchant_webapi/api/transactions",
    "VnpTmnCode": "__VNPAY_TMN_CODE__",
    "VnpHashSecret": "__VNPAY_HASH_SECRET__",
    "VnpReturnUrl": "https://portal.example.com/payment-status"
  }
}
