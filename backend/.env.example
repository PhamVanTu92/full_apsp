# Template environment variables cho docker-compose. Copy thành .env và set giá trị thật.
# .env nằm trong .gitignore — KHÔNG commit.
#
# Lưu ý format: ASP.NET Core Configuration tự bind `__` (double underscore)
# trong env var name → `:` trong appsettings key. Ví dụ:
#   Jwt__Key  →  Configuration["Jwt:Key"]

# ─── Database (encrypted theo EncryptDecrypt utility nội bộ) ───
ConnectionStrings__DefaultConnection=__ENCRYPTED_CONNECTION_STRING__

# ─── JWT ───
Jwt__Key=__ENCRYPTED_JWT_KEY_BASE64__
Jwt__Issuer=https://api.example.com
Jwt__Audience=https://app.example.com

# ─── SAP B1 Service Layer (encrypted) ───
SAPServiceLayer__Host=https://172.16.10.1:50000/b1s/v1/
SAPServiceLayer__CompanyDB=__ENCRYPTED_SAP_DB__
SAPServiceLayer__Username=__ENCRYPTED_SAP_USER__
SAPServiceLayer__Password=__ENCRYPTED_SAP_PASS__

# ─── SMTP ───
SmtpSettings__Password=__SMTP_PASSWORD__
