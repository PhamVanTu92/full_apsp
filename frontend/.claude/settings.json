{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run dev)",
      "Bash(npm run build:dev)",
      "Bash(npm run build:uat)",
      "Bash(npm run product)",
      "Bash(npm run preview)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(rm -rf*)"
    ]
  }
}
